_G.showTypoStats = function()
    local rate = typoStats.total > 0 and (typoStats.typos / typoStats.total * 100) or 0
    print(string.format("📊 Typo Stats: %d/%d words (%.1f%% typo rate)", typoStats.typos, typoStats.total, rate))
end
_G.resetTypoStats = function() typoStats = { total = 0, typos = 0 } print("Typo stats reset") end
_G.setTypoRate = function(rate)
    TYPO_CONFIG.typoChancePerWord = math.min(0.5, math.max(0.05, rate))
    print("Typo rate set to " .. (TYPO_CONFIG.typoChancePerWord * 100) .. "%")
end

